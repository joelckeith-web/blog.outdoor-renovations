{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "blog.outdoorreno.com" }],
      "destination": "https://www.outdoorreno.com/blog",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "has": [{ "type": "host", "value": "blog.outdoorreno.com" }],
      "destination": "https://www.outdoorreno.com/blog/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "blog.outdoorreno.com" }],
      "destination": "https://www.outdoorreno.com/blog/:path*",
      "permanent": true
    }
  ]
}
